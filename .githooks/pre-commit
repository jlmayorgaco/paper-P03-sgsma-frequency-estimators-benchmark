#!/usr/bin/env bash
set -euo pipefail

limit_bytes=$((100 * 1024 * 1024))

staged_files=$(git diff --cached --name-only --diff-filter=AM)

if [ -z "${staged_files}" ]; then
  exit 0
fi

while IFS= read -r file; do
  [ -z "${file}" ] && continue
  if [ ! -f "${file}" ]; then
    continue
  fi
  size=$(wc -c < "${file}")
  if [ "${size}" -gt "${limit_bytes}" ]; then
    size_mb=$(awk "BEGIN { printf \"%.2f\", ${size}/1024/1024 }")
    echo "ERROR: '${file}' is ${size_mb} MB and exceeds the 100 MB commit limit."
    echo "Remove it from staging with: git restore --staged \"${file}\""
    exit 1
  fi
done <<< "${staged_files}"

exit 0
