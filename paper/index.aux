\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces Trip-Risk Analysis: Multi-Event Scenario (E). $T_{\mathrm  {trip}}$: cumulative time with $|e(t)|>0.5$\,Hz; CPU: mean time per sample ($\mu $s), Scenario~E run. Values: mean $\pm $ std from Monte Carlo (N=30). Methods not shown: TKEO (RMSE\,$\geq \!7.8$\,Hz, diverges); RLS ($0.342$\,Hz, $T_{\mathrm  {trip}}\!=\!0.367$\,s, CPU\,$=\!12.7\,\mu $s; similar to EKF); RLS-VFF ($0.874$\,Hz, $T_{\mathrm  {trip}}\!=\!2.20$\,s); TFT ($T_{\mathrm  {trip}}\!=\!0.349$\,s); PI-GRU ($1.83$\,Hz, $T_{\mathrm  {trip}}\!=\!3.76$\,s, CPU\,$\approx \!1.54\!\times \!10^5\,\mu $s; Table~\ref {tab:complexity}).}}{5}{table.caption.5}\protected@file@percent }
\newlabel{tab:risk_metrics}{{IV}{5}{Trip-Risk Analysis: Multi-Event Scenario (E). $T_{\mathrm {trip}}$: cumulative time with $|e(t)|>0.5$\,Hz; CPU: mean time per sample ($\mu $s), Scenario~E run. Values: mean $\pm $ std from Monte Carlo (N=30). Methods not shown: TKEO (RMSE\,$\geq \!7.8$\,Hz, diverges); RLS ($0.342$\,Hz, $T_{\mathrm {trip}}\!=\!0.367$\,s, CPU\,$=\!12.7\,\mu $s; similar to EKF); RLS-VFF ($0.874$\,Hz, $T_{\mathrm {trip}}\!=\!2.20$\,s); TFT ($T_{\mathrm {trip}}\!=\!0.349$\,s); PI-GRU ($1.83$\,Hz, $T_{\mathrm {trip}}\!=\!3.76$\,s, CPU\,$\approx \!1.54\!\times \!10^5\,\mu $s; Table~\ref {tab:complexity})}{table.caption.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {V}{\ignorespaces Computational Cost per Sample (Python Baselines). CPU: mean time per sample over 20 runs on an Intel Core Ultra 5 125H (single-threaded Python~3.13; not C or FPGA projections). Deployment class: P1 ($<$20\,$\mu $s, embedded MCU), P2 (20--40\,$\mu $s, DSP), M1 ($>$40\,$\mu $s, DSP/FPGA or higher); these are per-sample execution time thresholds, not estimator response-latency classes.}}{5}{table.caption.6}\protected@file@percent }
\newlabel{tab:complexity}{{V}{5}{Computational Cost per Sample (Python Baselines). CPU: mean time per sample over 20 runs on an Intel Core Ultra 5 125H (single-threaded Python~3.13; not C or FPGA projections). Deployment class: P1 ($<$20\,$\mu $s, embedded MCU), P2 (20--40\,$\mu $s, DSP), M1 ($>$40\,$\mu $s, DSP/FPGA or higher); these are per-sample execution time thresholds, not estimator response-latency classes}{table.caption.6}{}}
