\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Comprehensive Performance Dashboard. \textbf  {(a)}~Phase-Jump Robustness (Scen.~D): RA-EKF event-gating limits trip-risk to ${\approx }0.40$\,ms vs.\ 122\,ms for standard EKF. \textbf  {(b)}~Ramp Tracking (Scen.~B): RA-EKF achieves lowest RMSE via explicit $\dot  {\omega }$ state; IpDFT uses 2-cycle grid-search window (33\,ms) and achieves RMSE\,$=0.035$\,Hz; SOGI-FLL fails (RMSE\,$=1.12$\,Hz), outside loop bandwidth. \textbf  {(c--d)}~Multi-Event: stable vs.\ unstable estimators (TKEO excluded, RMSE\,$\geq 7.8$\,Hz). \textbf  {(e)}~Pareto frontier ($\dagger $PI-GRU excluded, CPU\,${\approx }154$\,ms/sample, Trip\,${\approx }3.8$\,s). \textbf  {(f)}~Radar profile. \textbf  {(g)}~Compliance heatmap [RMSE\,$<0.05$\,Hz, Peak\,$<0.5$\,Hz, Trip\,$<0.1$\,s]; RA-EKF Islanding: peak\,$=0.365$\,Hz (below $0.5$\,Hz threshold; $T_{\mathrm  {trip}}=0$). \textbf  {(h)}~Steady-state error (log scale, Scen.~C). Subfigures: (a)--(d) time-domain, (e)--(f) aggregate, (g)--(h) compliance/steady-state.}}{6}{figure.caption.7}\protected@file@percent }
\newlabel{fig:dashboard_mega}{{2}{6}{Comprehensive Performance Dashboard. \textbf {(a)}~Phase-Jump Robustness (Scen.~D): RA-EKF event-gating limits trip-risk to ${\approx }0.40$\,ms vs.\ 122\,ms for standard EKF. \textbf {(b)}~Ramp Tracking (Scen.~B): RA-EKF achieves lowest RMSE via explicit $\dot {\omega }$ state; IpDFT uses 2-cycle grid-search window (33\,ms) and achieves RMSE\,$=0.035$\,Hz; SOGI-FLL fails (RMSE\,$=1.12$\,Hz), outside loop bandwidth. \textbf {(c--d)}~Multi-Event: stable vs.\ unstable estimators (TKEO excluded, RMSE\,$\geq 7.8$\,Hz). \textbf {(e)}~Pareto frontier ($\dagger $PI-GRU excluded, CPU\,${\approx }154$\,ms/sample, Trip\,${\approx }3.8$\,s). \textbf {(f)}~Radar profile. \textbf {(g)}~Compliance heatmap [RMSE\,$<0.05$\,Hz, Peak\,$<0.5$\,Hz, Trip\,$<0.1$\,s]; RA-EKF Islanding: peak\,$=0.365$\,Hz (below $0.5$\,Hz threshold; $T_{\mathrm {trip}}=0$). \textbf {(h)}~Steady-state error (log scale, Scen.~C). Subfigures: (a)--(d) time-domain, (e)--(f) aggregate, (g)--(h) compliance/steady-state}{figure.caption.7}{}}
