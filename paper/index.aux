\@writefile{lot}{\contentsline {table}{\numberline {I}{\ignorespaces Unified Qualitative Benchmark of Frequency Estimators (relay-class, non-synchronized context). Scores ($0$=Fail, $1$=Poor, $2$=Fair, $3$=Excellent) are qualitative assessments derived from observed benchmark performance (this work; see Tables~II--III for quantitative evidence) and published literature~\cite  {Ferrero2020EKF,Golestan2015,PlatasGarza2011}; they are intended for algorithmic comparison and are not certification ratings. $h_{\mathrm  {HU}}$: Harmonic/Unbalance Immunity; $r_{32.5}$: rejection of 32.5\,Hz sub-synchronous interharmonic (representative of IBR converter control interactions~\cite  {Bernal2024}; used in Scenarios~D--E, Section~\ref {sec:scenarios}); $n_{\mathrm  {sens}}$: noise floor sensitivity; $n_{\mathrm  {NG}}$: Non-Gaussian noise robustness; Latency class: P1\,$<$\,20\,ms, P2: 20--40\,ms, M1\,$>$\,40\,ms, P3: sub-cycle ($<$1\,ms); $v_{\mathrm  {RT}}$: real-time viability (3=embedded, 0=GPU only); RoCoF Out.: S\,=\,explicit state output, D\,=\,implicit differentiation; \emph  {Phase Resp.}: phase-jump response type --- S\,=\,settles without cycle-slip, D\,=\,cycle-slip susceptible; $^\dagger $IpDFT latency is structural: $N_c/f_0 = 33$\,ms at $N_c\!=\!2$ to 167\,ms at $N_c\!=\!10$ (observation delay, not stochastic lag).}}{3}{table.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:unified_2024_big}{{I}{3}{Unified Qualitative Benchmark of Frequency Estimators (relay-class, non-synchronized context). Scores ($0$=Fail, $1$=Poor, $2$=Fair, $3$=Excellent) are qualitative assessments derived from observed benchmark performance (this work; see Tables~II--III for quantitative evidence) and published literature~\cite {Ferrero2020EKF,Golestan2015,PlatasGarza2011}; they are intended for algorithmic comparison and are not certification ratings. $h_{\mathrm {HU}}$: Harmonic/Unbalance Immunity; $r_{32.5}$: rejection of 32.5\,Hz sub-synchronous interharmonic (representative of IBR converter control interactions~\cite {Bernal2024}; used in Scenarios~D--E, Section~\ref {sec:scenarios}); $n_{\mathrm {sens}}$: noise floor sensitivity; $n_{\mathrm {NG}}$: Non-Gaussian noise robustness; Latency class: P1\,$<$\,20\,ms, P2: 20--40\,ms, M1\,$>$\,40\,ms, P3: sub-cycle ($<$1\,ms); $v_{\mathrm {RT}}$: real-time viability (3=embedded, 0=GPU only); RoCoF Out.: S\,=\,explicit state output, D\,=\,implicit differentiation; \emph {Phase Resp.}: phase-jump response type --- S\,=\,settles without cycle-slip, D\,=\,cycle-slip susceptible; $^\dagger $IpDFT latency is structural: $N_c/f_0 = 33$\,ms at $N_c\!=\!2$ to 167\,ms at $N_c\!=\!10$ (observation delay, not stochastic lag)}{table.caption.1}{}}
